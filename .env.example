PORT=5000
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME"
APP_BASE_URL="http://localhost:5000"
FRONTEND_BASE_URL="http://localhost:5173"

# Tracking code prefixes used for participantCode and applicationReference.
ORGANISATION_PREFIX="SS"
PROJECT_PREFIX="DF"

# S3 or MinIO settings
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET="your-bucket-name"
S3_FORCE_PATH_STYLE=true

# DHIS2 settings, to be used when we add the sync worker/endpoints
DHIS2_BASE_URL="https://your-dhis2-instance.org"
DHIS2_USERNAME="your-dhis2-username"
DHIS2_PASSWORD="your-dhis2-password"
DHIS2_ORG_UNIT_ID="your-org-unit-id"
DHIS2_TRACKED_ENTITY_TYPE_ID="your-tracked-entity-type-id"

# Email/SMTP settings used for test invitations
# For local testing, leave these blank and the backend will print the invitation link in the server console.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="Digital Futures Registration Portal"
SMTP_FROM_EMAIL="noreply@example.org"
BASIC_SKILLS_TEST_INVITE_EXPIRY_DAYS=14
