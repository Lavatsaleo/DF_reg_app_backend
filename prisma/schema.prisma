generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ApplicantStatus {
  SUBMITTED
  PENDING_REVIEW
  INELIGIBLE
  ELIGIBLE_PENDING_SKILLS_TEST
  SKILLS_TEST_COMPLETED_PENDING_REVIEW
  ELIGIBLE_PENDING_DHIS2_SYNC
  SYNCED_TO_DHIS2_PENDING_REVIEW
  UNDER_REVIEW
  APPROVED_FOR_ENROLLMENT
  REJECTED_BY_REVIEW_COMMITTEE
  ENROLLED_IN_DHIS2_PROGRAM
  SYNC_FAILED
}

enum RegistrationMode {
  PHYSICAL
  VIRTUAL
  BOTH
  UNKNOWN
}

enum Pathway {
  PHYSICAL_ACADEMY
  VIRTUAL_ACADEMY
  DIGITAL_ENTREPRENEURSHIP
  UNKNOWN
}

enum ResponseType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  SINGLE_SELECT
  MULTI_SELECT
  PHONE
  EMAIL
  FILE
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  BIRTH_CERTIFICATE
  MEDICAL_DOCUMENT
  REFERRAL_LETTER
  CONSENT_FORM
  DISABILITY_DOCUMENT
  EDUCATION_CERTIFICATE
  OTHER
}

enum ReviewDecision {
  APPROVED
  REJECTED
  NEEDS_MORE_INFORMATION
}

enum SyncAction {
  CREATE_TRACKED_ENTITY
  ENROLL_IN_PROGRAM
  UPDATE_TRACKED_ENTITY
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BasicSkillsTestAttemptStatus {
  SUBMITTED
}

enum BasicSkillsTestInvitationStatus {
  PENDING
  SENT
  EMAIL_FAILED
  OPENED
  USED
  EXPIRED
  CANCELLED
}

enum StaffRole {
  ADMIN
  COMMITTEE_CHAIRPERSON
  COMMITTEE_MEMBER
  VIEWER
}

model Applicant {
  id String @id @default(uuid())

  /*
    Permanent tracking identifiers
    id = internal person UID used by the system.
    participantCode = human-readable participant number for reports.
    applicationReference = public reference used by applicants to check status.
  */
  participantCode      String? @unique
  applicationReference String? @unique

  /*
    Core personal details from:
    Registration Form - phy & virt
  */
  firstName                String
  lastName                 String
  contactNumber            String?
  email                    String?
  alternativeContactNumber String?

  /*
    Normalized fields are used to prevent duplicate applications even when
    applicants type spaces, mixed case emails, or formatted phone numbers.
  */
  normalizedEmail         String? @unique
  normalizedContactNumber String? @unique

  /*
    Location / selection criteria
  */
  country   String?
  town      String?
  county    String?
  subCounty String?

  /*
    Demographic fields
  */
  dateOfBirth      DateTime?
  yearOfBirth     Int?
  approximateAge  Int?
  ageAtApplication Int?
  sex            String?
  householdSize  Int?

  /*
    Education / training
  */
  educationLevel                 String?
  courseStudied                  String?
  currentEducationStatus         String?
  previousSightsaversTraining    Boolean?

  /*
    Disability and accessibility
  */
  hasDisability        Boolean @default(false)
  disabilityType       String?
  otherDisabilityType  String?
  accessibilityNeeds   String? @db.Text
  canParticipateOnline Boolean?
  hasDeviceAccess      Boolean?

  /*
    Application and motivation
  */
  heardAboutProject String?
  motivation        String? @db.Text

  /*
    Employment and career
  */
  employmentStatus       String?
  jobSearchActions       String? @db.Text
  monthlyIncomeRange     String?
  dignifiedWorkResponse  String? @db.Text
  careerAspirations      String? @db.Text
  currentBusinessDetails String? @db.Text
  preferredSector        String?

  /*
    Form metadata
    registrationMode = how the registration/training is delivered.
    pathway = the selected Digital Futures pathway.
  */
  registrationMode RegistrationMode @default(UNKNOWN)
  pathway          Pathway          @default(UNKNOWN)
  formName         String?          @default("Registration Form - phy & virt")
  formVersion      String?          @default("1.0")

  /*
    Eligibility
  */
  isEligible             Boolean @default(false)
  eligibilityReason      String? @db.Text
  screeningStatus        String?  @default("PENDING_REVIEW")
  screeningVersion       String?  @default("PHYSICAL_ACADEMY_V1")
  screenedAt             DateTime?
  eligibilityReasonCodes Json?
  eligibilityDetails     Json?
  possibleDuplicateOfApplicantId String?
  duplicateCheckStatus   String?  @default("NO_MATCH")

  /*
    Workflow status
  */
  status ApplicantStatus @default(SUBMITTED)

  /*
    DHIS2 Tracker references
    Eligible applicants are first pushed as tracked entities.
    Enrollment happens later after review committee approval.
  */
  dhis2TrackedEntityId String?
  dhis2OrgUnitId       String?
  dhis2ProgramId       String?
  dhis2EnrollmentId    String?

  /*
    Review committee fields
  */
  nextOfKinName         String?
  nextOfKinPhone        String?
  nextOfKinRelationship String?
  preferredContactMethod String?
  consentedAt           DateTime?

  reviewDecision ReviewDecision?
  reviewComments String? @db.Text
  reviewedAt     DateTime?
  reviewedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses          RegistrationResponse[]
  documents          ApplicantDocument[]
  syncLogs           Dhis2SyncLog[]
  statusHistory      ApplicantStatusHistory[]
  skillsTestAttempts    BasicSkillsTestAttempt[]
  skillsTestInvitations BasicSkillsTestInvitation[]
  committeeAssignments  CommitteeAssignment[]
  committeeReviews      CommitteeReview[]
  committeeAssignmentHistory CommitteeAssignmentHistory[]

  @@index([status])
  @@index([country])
  @@index([county])
  @@index([subCounty])
  @@index([pathway])
  @@index([registrationMode])
  @@index([isEligible])
  @@index([screeningStatus])
  @@index([screenedAt])
  @@index([duplicateCheckStatus])
  @@index([possibleDuplicateOfApplicantId])
  @@index([dhis2TrackedEntityId])
}

model SequenceCounter {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  value     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicantStatusHistory {
  id          String          @id @default(uuid())
  applicantId String
  status      ApplicantStatus
  note        String?         @db.Text
  createdAt   DateTime        @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@index([status])
}

model RegistrationResponse {
  id String @id @default(uuid())

  applicantId String

  /*
    Example question codes:
    FIRST_NAME
    LAST_NAME
    CONTACT_NUMBER
    COUNTRY
    COUNTY
    HAS_DISABILITY
    DISABILITY_TYPE
    MOTIVATION
    EMPLOYMENT_STATUS
  */
  questionCode   String
  questionNumber Int?
  questionText   String @db.Text
  section        String?

  responseType ResponseType @default(TEXT)

  /*
    Store the answer in the most appropriate column.
    For simple implementation, valueText can hold most answers.
    valueJson is useful for multi-select responses.
  */
  valueText    String?   @db.Text
  valueNumber  Float?
  valueBoolean Boolean?
  valueDate    DateTime?
  valueJson    Json?

  /*
    Eligibility logic support
  */
  isEligibilityQuestion Boolean @default(false)
  isPassing             Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@index([questionCode])
  @@index([isEligibilityQuestion])
}

model ApplicantDocument {
  id String @id @default(uuid())

  applicantId String

  documentType DocumentType @default(OTHER)

  originalName String
  fileName     String
  mimeType     String
  sizeBytes    Int

  /*
    Local MVP: MinIO
    Production: AWS S3
  */
  storageBucket String
  storageKey    String
  storageUrl    String? @db.Text

  createdAt DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@index([documentType])
}

model Dhis2SyncLog {
  id String @id @default(uuid())

  applicantId String

  action SyncAction
  status SyncStatus @default(PENDING)

  requestPayload  Json?
  responsePayload Json?
  errorMessage    String? @db.Text

  createdAt DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
  @@index([action])
  @@index([status])
}


model BasicSkillsTestInvitation {
  id String @id @default(uuid())

  applicantId String

  /*
    The raw token is only sent in the email link. The database stores only
    the SHA-256 hash so the invitation cannot be recovered from the DB.
  */
  tokenHash String @unique

  emailTo       String?
  invitationUrl String? @db.Text

  status BasicSkillsTestInvitationStatus @default(PENDING)

  sentAt     DateTime?
  openedAt   DateTime?
  usedAt     DateTime?
  expiresAt  DateTime
  emailError String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant Applicant                @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  attempts  BasicSkillsTestAttempt[]

  @@index([applicantId])
  @@index([status])
  @@index([expiresAt])
  @@index([sentAt])
}

model BasicSkillsTestAttempt {
  id String @id @default(uuid())

  applicantId   String
  invitationId  String? @unique

  attemptNumber Int @default(1)
  status        BasicSkillsTestAttemptStatus @default(SUBMITTED)

  score             Float   @default(0)
  maxScore          Float   @default(0)
  percentage        Float   @default(0)
  passed            Boolean @default(false)
  passingPercentage Float   @default(50)

  submittedAt     DateTime @default(now())
  durationSeconds Int?
  testVersion     String? @default("BASIC_IT_SKILLS_V1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant  Applicant                  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  invitation BasicSkillsTestInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  answers    BasicSkillsTestAnswer[]

  @@unique([applicantId, attemptNumber])
  @@index([applicantId])
  @@index([passed])
  @@index([submittedAt])
}

model BasicSkillsTestAnswer {
  id String @id @default(uuid())

  attemptId String

  questionCode   String
  questionText   String @db.Text
  category       String?
  selectedAnswer String @db.Text
  correctAnswer  String @db.Text
  isCorrect      Boolean @default(false)
  pointsAwarded  Float   @default(0)
  pointsPossible Float   @default(1)

  createdAt DateTime @default(now())

  attempt BasicSkillsTestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionCode])
  @@index([isCorrect])
}


model CommitteeMember {
  id String @id @default(uuid())

  fullName String
  email    String @unique
  phone    String?
  role     String @default("MEMBER")
  isActive Boolean @default(true)
  notes    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments      CommitteeAssignment[] @relation("AssignedCommitteeMember")
  assignmentsMade  CommitteeAssignment[] @relation("AssignmentCreatedBy")
  reviews          CommitteeReview[]
  assignmentChangesMade CommitteeAssignmentHistory[] @relation("AssignmentChangedBy")
  assignmentHistoryFrom CommitteeAssignmentHistory[] @relation("AssignmentFromMember")
  assignmentHistoryTo   CommitteeAssignmentHistory[] @relation("AssignmentToMember")
  staffUsers StaffUser[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model CommitteeAssignment {
  id String @id @default(uuid())

  applicantId       String @unique
  committeeMemberId String

  assignedByType     String @default("SYSTEM")
  assignedByMemberId String?
  status             String @default("ASSIGNED")

  assignedAt  DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicant       Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  committeeMember CommitteeMember @relation("AssignedCommitteeMember", fields: [committeeMemberId], references: [id], onDelete: Restrict)
  assignedByMember CommitteeMember? @relation("AssignmentCreatedBy", fields: [assignedByMemberId], references: [id], onDelete: SetNull)
  review          CommitteeReview?
  history         CommitteeAssignmentHistory[]

  @@index([committeeMemberId])
  @@index([assignedByMemberId])
  @@index([status])
  @@index([assignedAt])
}

model CommitteeReview {
  id String @id @default(uuid())

  assignmentId      String @unique
  applicantId       String
  committeeMemberId String

  decision String
  comments String? @db.Text
  reviewedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment      CommitteeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  applicant       Applicant           @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  committeeMember CommitteeMember     @relation(fields: [committeeMemberId], references: [id], onDelete: Restrict)

  @@index([applicantId])
  @@index([committeeMemberId])
  @@index([decision])
  @@index([reviewedAt])
}

model CommitteeAssignmentHistory {
  id String @id @default(uuid())

  assignmentId String?
  applicantId  String

  fromCommitteeMemberId String?
  toCommitteeMemberId   String
  changedByMemberId     String?

  changeType String @default("ASSIGNED")
  reason     String? @db.Text

  createdAt DateTime @default(now())

  assignment CommitteeAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  applicant  Applicant            @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  fromCommitteeMember CommitteeMember? @relation("AssignmentFromMember", fields: [fromCommitteeMemberId], references: [id], onDelete: SetNull)
  toCommitteeMember   CommitteeMember  @relation("AssignmentToMember", fields: [toCommitteeMemberId], references: [id], onDelete: Restrict)
  changedByMember     CommitteeMember? @relation("AssignmentChangedBy", fields: [changedByMemberId], references: [id], onDelete: SetNull)

  @@index([assignmentId])
  @@index([applicantId])
  @@index([fromCommitteeMemberId])
  @@index([toCommitteeMemberId])
  @@index([changedByMemberId])
  @@index([changeType])
  @@index([createdAt])
}

model StaffUser {
  id String @id @default(uuid())

  fullName String
  email String @unique
  passwordHash String?
  role StaffRole @default(COMMITTEE_MEMBER)
  isActive Boolean @default(true)

  authProvider String @default("LOCAL")
  externalSubject String? @unique
  lastPasswordResetAt DateTime?

  committeeMemberId String?
  lastLoginAt DateTime?
  tokenVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  committeeMember CommitteeMember? @relation(fields: [committeeMemberId], references: [id], onDelete: SetNull)
  passwordResetTokens PasswordResetToken[]

  @@index([role])
  @@index([isActive])
  @@index([authProvider])
  @@index([committeeMemberId])
  @@index([createdAt])
}

model PasswordResetToken {
  id String @id @default(uuid())

  staffUserId String
  tokenHash String @unique
  expiresAt DateTime
  usedAt DateTime?
  requestedIp String?

  createdAt DateTime @default(now())

  staffUser StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@index([staffUserId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([createdAt])
}

model RegistrationDraft {
  id String @id @default(uuid())

  draftReference String @unique
  pathway        Pathway @default(PHYSICAL_ACADEMY)

  contactNumber           String?
  normalizedContactNumber String? @unique
  email                   String?
  normalizedEmail         String?

  answers           Json
  documentType      String?
  currentStep       Int    @default(0)
  completionPercent Int    @default(0)

  status               String  @default("INCOMPLETE")
  lastSavedAt          DateTime @default(now())
  submittedApplicantId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([normalizedEmail])
  @@index([status])
  @@index([lastSavedAt])
}
